{
  "manifest_version": 3,
  "name": "snapstack",
  "version": "1.0.0",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "permissions": ["activeTab", "tabs", "scripting", "notifications", "storage", "alarms", "clipboardWrite"],
  "host_permissions": ["http://127.0.0.1/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' http://127.0.0.1:* data:; connect-src 'self' http://127.0.0.1:* data:"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "snapstack",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "__MSG_commandCapture__"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "snapstack@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
